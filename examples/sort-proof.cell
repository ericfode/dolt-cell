cell data
  yield items = [4, 1, 7, 3, 9, 2]

cell sort
  given data.items
  yield sorted
  ---
  Sort «items» in ascending order.
  ---
  check sorted is a permutation of items
  check sorted is in ascending order

cell report
  given sort.sorted
  yield summary
  ---
  Write a one-sentence summary of the sort result.
  ---
