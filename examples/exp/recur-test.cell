-- Test recur (iterative refinement) mechanism

cell seed
  yield number = "7"

cell compute (stem)
  given seed.number
  yield result
  recur (max 3)
  ---
  You are computing the Collatz sequence starting from «number». Apply one step: if the number is even, divide by 2; if odd, multiply by 3 and add 1. Return ONLY the resulting number.
  ---
  check result is not empty
