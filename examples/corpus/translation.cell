cell source
  yield text = Hello, how are you today?
  yield target_lang = Spanish

cell translate
  given source.text
  given source.target_lang
  yield translated
  ---
  Translate «text» into «target_lang».
  ---

cell back_translate
  given translate.translated
  yield round_trip
  ---
  Translate «translated» back into English.
  ---
  check round_trip preserves the meaning of the original text
