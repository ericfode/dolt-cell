;; cell-zero.zygo — The Metacircular Evaluator in S-Expressions
;;
;; This is the Zygo substrate version of the metacircular evaluator.
;; It proves the cell language can express its own evaluator without
;; leaving the abstraction — no SQL, no reflection, no escape hatches.
;;
;; Sussman's criterion: "A language that can express its own evaluator
;; in itself is a language that can be extended by its users without
;; modifying the implementation."
;;
;; This file demonstrates ALL cell body types in the Zygo substrate:
;;   - Hard literal (pure, no body)
;;   - Soft cell (replayable, LLM-evaluated string body)
;;   - Pure compute (pure, Zygo expression body — replaces sql:)
;;   - Stem cell (non-replayable, perpetual, returns :more)
;;   - Autopour (cell yields a program, runtime pours it)
;;
;; Compare with:
;;   cell-zero-autopour.cell — same semantics, old cell syntax, sql: bodies
;;   cell-zero-eval.cell     — SQL escape hatch version (proves runtime, not language)
;;
;; Design doc: docs/plans/2026-03-21-zygo-substrate-design.md
;; Bead: dc-61m
;; Author: Sussmind (2026-03-21)

;; ============================================================
;; PART 1: The Universal Evaluator
;;
;; Accept a program as S-expression text, yield it for autopour.
;; That's it. That's eval.
;; ============================================================

;; A pour-request: another cell or external agent fills in the
;; program name and the S-expression source of the program to evaluate.
(defcell request
  {:yield [:program-name :program-text]
   :effect :replayable
   :check [(not-empty? program-name)
           (not-empty? program-text)]}
  (str "Yield the program name and S-expression source text "
       "for the program to be evaluated."))

;; The universal evaluator. Takes program-text and yields it
;; for autopour. The runtime parses the S-expression, verifies
;; its effect level, and pours it into the retort.
;;
;; If the text doesn't parse → bottom (error).
;; If the effect level exceeds the bound → bottom.
;; Otherwise, the program enters the retort and starts evaluating.
;;
;; This IS eval. eval = pour. A cell that yields a program IS
;; an evaluator. The runtime does the rest.
(defcell evaluator
  {:given [request/program-text request/program-name]
   :yield [:evaluated :name]
   :effect :non-replayable
   :autopour [:evaluated]
   :check [(not-empty? evaluated)]}
  {:evaluated program-text
   :name program-name})

;; ============================================================
;; PART 2: Observing Results (Pure Compute — replaces sql:)
;;
;; Once a program is poured, its cells evaluate normally via the
;; runtime. We observe results through the `observe` primitive.
;;
;; In the old syntax, this was a sql: body reading from the cells
;; table. In the Zygo substrate, it's a pure function over
;; observed tuple space state.
;; ============================================================

;; Check the status of the poured program.
;; Uses observe (Replayable tier) instead of sql: (which was
;; incorrectly classified as Pure in the old syntax).
(defcell status
  {:given [evaluator/name]
   :yield [:state]
   :effect :replayable}
  (let [cells (observe name :cells)
        total (len cells)
        bottoms (len (filter (fn [c] (= (:state c) "bottom")) cells))
        unfrozen (len (filter (fn [c] (!= (:state c) "frozen")) cells))]
    {:state (cond
              (= total 0) "not_found"
              (> bottoms 0) "error"
              (= unfrozen 0) "complete"
              :else "running")}))

;; ============================================================
;; PART 3: The Self-Evaluation Question
;;
;; Can this evaluator evaluate itself?
;;
;; If request/program-text contains the text of THIS program
;; (cell-zero.zygo), then:
;;
;; 1. evaluator receives its own source as program-text
;; 2. evaluator yields it with :autopour
;; 3. Runtime parses the S-expression and pours a copy
;; 4. The copy's request cell needs program-text — from where?
;; 5. Nobody provides it → the copy's request sits unsatisfied
;; 6. The copy is inert. Self-evaluation terminates NATURALLY.
;;
;; This is CORRECT. The self-application of eval to eval produces
;; an inert copy. It doesn't diverge because the poured copy has
;; an unsatisfied dependency (request/program-text). The DAG acts
;; as a natural termination condition.
;;
;; No fuel needed for self-evaluation.
;;
;; Fuel is needed only for CHAINED autopour:
;;   Program A autopours Program B which autopours Program C...
;;   Each pour decrements fuel. At fuel=0, autopour yields bottom.
;;
;; This is proven formally in Autopour.lean:
;;   - selfEvalTower_terminates: the tower always ends with bottom
;;   - fuel_decreases: each step consumes fuel
;;   - DAG termination: unsatisfied deps = natural stop
;;
;; ============================================================

;; ============================================================
;; PART 4: The Perpetual Evaluator (Stem Version)
;;
;; A stem cell that continuously accepts pour-requests and
;; evaluates them. Stem cells return :more to request another
;; cycle — no self-spawning via SQL INSERTs needed.
;; ============================================================

;; Perpetual request poller. This is a stem cell — it runs
;; forever, checking each generation for new work via observe.
(defcell perpetual-request
  {:yield [:program-name :program-text]
   :effect :non-replayable
   :stem true}
  (fn [env]
    (let [pending (observe "cell-zero" :pending-requests)]
      (if (nil? pending)
        [{:program-name "" :program-text ""} :more]
        [{:program-name (:name (car pending))
          :program-text (:text (car pending))} :more]))))

;; Perpetual evaluator. If program-text is not empty, yield it
;; for autopour. If empty, quiesce (no work this generation).
(defcell perpetual-evaluator
  {:given [perpetual-request/program-text
           perpetual-request/program-name]
   :yield [:poured :status]
   :effect :non-replayable
   :stem true
   :autopour [:poured]}
  (fn [env]
    (if (= program-text "")
      [{:poured "" :status "quiescent"} :more]
      [{:poured program-text :status "evaluating"} :more])))

;; ============================================================
;; PART 5: Demonstration — A Self-Contained Example
;;
;; A hard literal cell + pure compute cell showing that the
;; Zygo substrate handles all cell types without sql:.
;; ============================================================

;; Hard literal: a pure value, no computation needed.
(defcell example-topic
  {:yield [:subject]
   :effect :pure}
  {:subject "the metacircular evaluator"})

;; Soft cell: LLM-evaluated. The piston reads the string body
;; and produces yields. No sql:, no guillemets — just Zygo
;; string interpolation.
(defcell example-haiku
  {:given [example-topic/subject]
   :yield [:poem]
   :effect :replayable
   :check [(not-empty? poem)
           (check~ "poem follows 5-7-5 syllable pattern")]}
  (str "Write a haiku about " subject ". "
       "Follow 5-7-5 syllable structure. "
       "Return only the three lines."))

;; Pure compute: replaces what was sql: in the old syntax.
;; This is a Zygo expression — deterministic, no LLM needed.
;; The effect level is honestly :pure.
(defcell example-word-count
  {:given [example-haiku/poem]
   :yield [:total]
   :effect :pure}
  {:total (str (+ 1 (len (split (trim poem) " "))))})

;; ============================================================
;; DESIGN NOTES
;;
;; What's different from cell-zero-autopour.cell:
;;
;; 1. NO PARSER. The cell language IS S-expressions. Zygo's
;;    reader handles syntax. defcell is a macro, not a grammar.
;;
;; 2. NO SQL. The status cell uses observe (Replayable tier)
;;    instead of sql: (which was incorrectly classified as Pure).
;;    Pure compute cells use Zygo expressions directly.
;;
;; 3. NO GUILLEMETS. Variable binding is native Zygo. Given
;;    values are bound as Zygo variables in the cell body's
;;    evaluation environment. «field» → just use the symbol.
;;
;; 4. HONEST EFFECTS. Every cell declares its actual effect
;;    level. The runtime verifies at pour time via static
;;    effect checking (checkEffects in ZygoSemantics.lean).
;;    effect_safety theorem guarantees soundness.
;;
;; 5. REIFICATION IS SAFE. quote turns code into data (Pure).
;;    read-string turns data into code (NonReplayable).
;;    The asymmetry is intentional — reification over reflection.
;;
;; What this proves:
;;
;; With defcell + :autopour + stem cells + observe, the cell
;; language CAN express its own evaluator entirely within the
;; S-expression abstraction. No escape hatches. No reflection.
;; No SQL. The language is metacircular.
;;
;; Formally verified:
;;   - effect_safety (ZygoSemantics.lean): static check ⟹ runtime safety
;;   - checkEffects_mono: effect check is monotone across tiers
;;   - selfEvalTower_terminates (Autopour.lean): chained autopour terminates
;;   - fuel_decreases: each pour consumes fuel
;;   - crystallization_sound: soft→pure promotion preserves behavior
;;
;; The Lean is the truth. The code bends to match the proofs.
;; ============================================================
