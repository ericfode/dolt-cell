   "metacircularity": {
      "answer": "Structurally yes, executionally no.",
      "chained_autopour": {
         "explanation": "A pours B pours C... requires a fuel bound. Each pour decrements fuel. At fuel=0, autopour yields bottom. This is a runtime invariant, not expressible in the static program description.",
